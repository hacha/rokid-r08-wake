<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- R08Wake launcher icon: two distinct motifs — a twin-bell alarm clock (the "wake"
         metaphor, drawn as a line glyph, on top) and a separate wearable smart ring
         (a solid elliptical band, below). White on the black (see-through) background,
         within the adaptive-icon safe zone. -->

    <!-- ===== alarm clock (upper) ===== -->

    <!-- hammer knob between the bells -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52,28.5 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0" />

    <!-- left bell, tilted outward -->
    <group android:rotation="-30" android:pivotX="45.5" android:pivotY="34">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M42,34 C42,30 44,28.5 45.5,28.5 C47,28.5 49,30 49,34 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M44.2,27.8 a1.3,1.3 0 1,0 2.6,0 a1.3,1.3 0 1,0 -2.6,0" />
    </group>

    <!-- right bell, tilted outward -->
    <group android:rotation="30" android:pivotX="62.5" android:pivotY="34">
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M59,34 C59,30 61,28.5 62.5,28.5 C64,28.5 66,30 66,34 Z" />
        <path
            android:fillColor="#FFFFFF"
            android:pathData="M61.2,27.8 a1.3,1.3 0 1,0 2.6,0 a1.3,1.3 0 1,0 -2.6,0" />
    </group>

    <!-- clock body -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M41,43 a13,13 0 1,0 26,0 a13,13 0 1,0 -26,0" />

    <!-- clock hands (10:10) -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M54,43 L50,38 M54,43 L58,38" />

    <!-- hub -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M52,43 a2,2 0 1,0 4,0 a2,2 0 1,0 -4,0" />

    <!-- ===== smart ring (lower), a solid elliptical band ===== -->
    <path
        android:fillColor="#FFFFFF"
        android:fillType="evenOdd"
        android:pathData="M43,70 a11,6 0 1,0 22,0 a11,6 0 1,0 -22,0 M47.5,70 a6.5,3 0 1,0 13,0 a6.5,3 0 1,0 -13,0" />
</vector>
